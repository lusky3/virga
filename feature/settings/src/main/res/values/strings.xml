    <string name="settings_about_footer">Virga %1$s</string>
    <string name="settings_how_virga_works_title">How Virga works</string>
    <string name="settings_how_virga_works_body">Virga schedules sync tasks that run rclone in the background. Each task has a source and destination remote (a cloud drive, local folder, or SD card). Tasks run automatically when their conditions are met — Wi-Fi, charging state, or on a schedule.\n\nRemotes are configured using rclone\'s standard config. Virga stores the rclone config securely on-device. All sync operations run locally; no data passes through Virga\'s servers.</string>
    <string name="settings_licenses_title">Open-source licenses</string>
    <string name="settings_licenses_intro">Virga is built with these open-source projects. Tap any item to view it. Thank you to their authors.</string>
    <string name="settings_dialog_ok">OK</string>
    <string name="settings_snack_no_browser">No browser app found</string>
    <string name="settings_section_storage">Storage access</string>
    <string name="settings_storage_hint">Virga needs all-files access to read and write the folders you sync. Grant it here if you skipped this during setup.</string>
    <string name="settings_btn_grant_storage">Grant storage access</string>
    <string name="settings_snack_no_storage_settings">Couldn\'t open storage settings on this device</string>
    <string name="settings_snack_no_battery_settings">Couldn\'t open battery settings on this device</string>
    <string name="settings_section_security">Security</string>
    <string name="settings_toggle_app_lock">App lock</string>
    <string name="settings_app_lock_hint">Locks the app\'s screen with your device biometric or PIN. It does not add encryption — your sync data is already encrypted at rest by rclone. Background syncs and the sync service keep running while the app is locked.</string>
    <string name="settings_section_quiet_hours">Quiet hours</string>
    <string name="settings_toggle_quiet_hours">Enable quiet hours</string>
    <string name="settings_quiet_hours_hint">Scheduled syncs are paused during this window. Manual syncs always run immediately regardless of quiet hours.</string>
    <string name="settings_quiet_hours_start">Start time</string>
    <string name="settings_quiet_hours_end">End time</string>
    <string name="settings_section_history">Run history</string>
    <string name="settings_retention_label">Keep history for</string>
    <string name="settings_retention_hint">Run history older than this limit will be removed at startup. Choose "Forever" to keep all history.</string>
    <string name="settings_retention_forever">Forever</string>
    <string name="settings_retention_30">30 days</string>
    <string name="settings_retention_90">90 days</string>
    <string name="settings_retention_180">180 days</string>
    <string name="settings_retention_365">365 days</string>

