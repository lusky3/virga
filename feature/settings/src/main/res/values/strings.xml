    <string name="settings_section_battery">Battery &amp; reliability</string>
    <string name="settings_battery_hint">Some manufacturers aggressively kill background apps, which can stop scheduled syncs. Exempt Virga from battery optimization and see dontkillmyapp.com for device-specific steps.</string>
    <string name="settings_btn_battery_settings">Battery settings</string>
    <string name="settings_btn_dontkillmyapp">dontkillmyapp.com</string>
    <string name="settings_toggle_watchdog">Keep Virga running (watchdog)</string>
    <string name="settings_watchdog_hint">Runs a persistent background service with a quiet ongoing notification so scheduled syncs aren\'t killed on aggressive devices. Uses a little extra battery — leave off unless your syncs keep getting skipped.</string>
    <string name="settings_section_privacy">Privacy</string>
    <string name="settings_toggle_crash_reporting">Send crash reports</string>
    <string name="settings_crash_reporting_hint">Off by default. When on, anonymous crash reports (stack traces with file paths, remote names, and tokens stripped out) are sent to help fix bugs. No file contents, accounts, or sync data are ever sent.</string>
