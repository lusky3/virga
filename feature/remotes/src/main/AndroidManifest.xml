<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- OAuthRedirectActivity (this module's class) is declared in the APP manifest,
         not here. Its Google intent-filter uses the ${googleOAuthScheme} placeholder
         derived from the app's client ID; a library resolves its own placeholders
         before the app merges, so a library-declared filter baked the wrong scheme
         (…unset) and broke the redirect. The class lives here; the manifest entry
         lives in :app. Unit tests exercise classifyOAuthRedirect directly and need
         no manifest declaration. -->

</manifest>
