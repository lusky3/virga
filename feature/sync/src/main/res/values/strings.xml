    <!-- Step 1: Intro -->
    <string name="wizard_intro_heading">Back up a folder to the cloud</string>
    <string name="wizard_intro_body">A sync task keeps a folder on your phone copied to a cloud account — automatically, on a schedule you control. You can sync to Google Drive, Dropbox, S3, or any remote you configure.</string>
    <string name="wizard_intro_steps">This wizard will walk you through:\n\n• Choosing a cloud account\n• Picking the folder to back up\n• Setting a destination path\n• Naming your task</string>
