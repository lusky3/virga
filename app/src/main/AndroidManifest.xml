<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Storage -->
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Background work -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
    <!-- Optional persistent watchdog (off by default). FLAVOR NOTE: relocate to
         app/src/foss/ alongside WatchdogService if Play rejects `specialUse`. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <application
        android:name=".VirgaApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false"
        android:roundIcon="@mipmap/ic_launcher"
        android:supportsRtl="true"
        android:theme="@style/Theme.Virga"
        android:enableOnBackInvokedCallback="true"
        android:localeConfig="@xml/locales_config">

        <!-- Enable AppCompat's automatic per-app locale storage so the override
             chosen in Settings is persisted and restored synchronously before
             onCreate (across the minSdk-26 backport range), with no startup race. -->
        <service
            android:name="androidx.appcompat.app.AppLocalesMetadataHolderService"
            android:enabled="false"
            android:exported="false">
            <meta-data
                android:name="autoStoreLocales"
                android:value="true" />
        </service>

        <!-- Crash reporting is OPT-IN. Disable the Sentry SDK's ContentProvider
             auto-init so it never starts on its own; CrashReporter initializes it
             manually only after the user enables the Settings toggle (and only when a
             DSN is configured). This keeps the FOSS build free of unsolicited network
             calls by default. -->
        <meta-data android:name="io.sentry.auto-init" android:value="false" />

        <!-- SEC-L: production builds are intentionally NOT profileable. The
             androidx.baselineprofile plugin creates dedicated, profileable
             `nonMinifiedRelease` / `benchmarkRelease` variants for the
             :benchmark module to attach to, so no <profileable> element is
             needed here — and omitting it keeps adb/shell profiling off the
             shipping release APK. Debug builds are debuggable and therefore
             already profileable locally. -->

        <!-- SEC: exported is required for the MAIN/LAUNCHER intent-filter.
             tools:ignore suppresses the static-analysis false-positive — the
             launcher activity has no privileged access to app internals beyond
             what any app entry-point normally has. -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Virga"
            android:windowSoftInputMode="adjustResize|stateAlwaysHidden"
            tools:ignore="ExportedActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- D7b (0.3.0): Add-remote shortcut action. The "Add remote" static
                 launcher shortcut fires this action so MainActivity can map it to
                 pendingRoute = ROUTE_ADD_REMOTE without relying on extras (which are
                 not reliable in static shortcut intents across all OEM launchers). -->
            <intent-filter>
                <action android:name="app.lusk.virga.action.SHORTCUT_ADD_REMOTE" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
            <!-- D7b (0.3.0): Static launcher shortcuts (sync all + add remote). -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <!-- D7b (0.3.0): Sync-all launcher shortcut trampoline.
             SEC: exported=true is required for the launcher to start this activity
             from outside the app process. It exposes no privileged internals; it
             only enqueues the same work as tapping "Back up now" in the app.
             excludeFromRecents keeps it out of the task switcher. The
             Theme.NoDisplay system theme suppresses the window entirely so there
             is no UI flash. -->
        <activity
            android:name=".widget.SyncAllShortcutActivity"
            android:exported="true"
            android:excludeFromRecents="true"
            android:theme="@android:style/Theme.NoDisplay"
            android:taskAffinity=""
            tools:ignore="ExportedActivity" />

        <!-- On-demand WorkManager initialisation (we supply the config via
             Configuration.Provider with the Hilt worker factory). -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- SEC-L2: WorkManager's diagnostics receiver (exported, DUMP-protected) only
             dumps internal queue state for adb tooling we don't use in production —
             strip it to remove the attack surface. (ProfileInstallReceiver is kept:
             it is needed by the baseline-profile/benchmark tooling and is DUMP-gated.) -->
        <receiver
            android:name="androidx.work.impl.diagnostics.DiagnosticsReceiver"
            tools:node="remove" />

        <!-- The sync runs as a dataSync foreground service. WorkManager's library
             manifest declares SystemForegroundService WITHOUT a
             foregroundServiceType, so on API 31+ calling
             setForeground(FOREGROUND_SERVICE_TYPE_DATA_SYNC) throws
             "foregroundServiceType 0x1 is not a subset of 0x0" and crashes the
             process mid-sync. Merge the dataSync type onto the service so the
             type the worker requests is actually declared. -->
        <service
            android:name="androidx.work.impl.foreground.SystemForegroundService"
            android:foregroundServiceType="dataSync"
            tools:node="merge" />

        <!-- F3 (0.3.0): FileProvider for sharing/opening exported files (config
             export, history CSV/JSON, file open/share/download). Backed by the
             app's cache dir so shared artifacts are transient and never world-
             readable on disk. exported=false + grantUriPermissions: only the
             specific content:// URIs we hand out via Intent are accessible. -->
        <provider
            android:name=".VirgaFileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- D7a (0.3.0): Share-target receiver — lets users share files from
             any app into Virga for upload to a configured remote.
             SEC: exported is required for ACTION_SEND share targets; the system
             and sharing apps must be able to start this activity. The activity
             only reads the incoming EXTRA_STREAM URI(s); it exposes no privileged
             Virga internals and performs no writes beyond copying the URI into
             the app's own cache directory. -->
        <activity
            android:name=".share.ShareReceiverActivity"
            android:exported="true"
            android:theme="@style/Theme.Virga"
            android:label="@string/share_receiver_label"
            android:excludeFromRecents="true"
            tools:ignore="ExportedActivity">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND_MULTIPLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:mimeType="*/*" />
            </intent-filter>
        </activity>

        <!-- Phase 3 WS3.6: Glance home-screen widget.
             SEC: exported is required by the AppWidget framework — the launcher
             must be able to send APPWIDGET_UPDATE. The receiver exposes no
             privileged operations; it only renders the widget UI. -->
        <receiver
            android:name=".widget.SyncWidgetReceiver"
            android:exported="true"
            android:label="@string/widget_description"
            tools:ignore="ExportedReceiver">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE" />
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/sync_widget_info" />
        </receiver>

        <!-- Phase 3 WS3.6: Quick Settings tile.
             SEC: exported is required by the QS framework — the system binds
             this service. The android:permission attribute restricts callers to
             the system (only the system holds BIND_QUICK_SETTINGS_TILE), so no
             third-party app can invoke it. -->
        <service
            android:name=".widget.SyncTileService"
            android:exported="true"
            android:icon="@drawable/ic_tile_sync"
            android:label="@string/tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE"
            tools:ignore="ExportedService">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
        </service>

    </application>
</manifest>
