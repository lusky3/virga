<?xml version="1.0" encoding="utf-8"?>
<!--
  Static launcher shortcuts (D7b, 0.3.0).

  Package-agnostic routing: both intents use only android:action with no
  targetPackage or targetClass. This means the shortcuts resolve correctly
  regardless of applicationIdSuffix (debug = app.lusk.virga.debug, release =
  app.lusk.virga). Each action is unique to this app, so there is no ambiguity.

  "Add remote": fires app.lusk.virga.action.SHORTCUT_ADD_REMOTE; MainActivity
  has a matching intent-filter and maps it to pendingRoute = ROUTE_ADD_REMOTE.

  "Sync all": fires app.lusk.virga.action.SHORTCUT_SYNC_ALL; SyncAllShortcut-
  Activity has a matching intent-filter and enqueues syncAllEnabled().
-->
<shortcuts xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shortcut 1: Sync all — triggers the no-UI trampoline activity. -->
    <shortcut
        android:shortcutId="sync_all"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_sync"
        android:shortcutShortLabel="@string/shortcut_sync_all_short"
        android:shortcutLongLabel="@string/shortcut_sync_all_long">
        <intent android:action="app.lusk.virga.action.SHORTCUT_SYNC_ALL" />
    </shortcut>

    <!-- Shortcut 2: Add remote — opens MainActivity and deep-links to Add-Remote. -->
    <shortcut
        android:shortcutId="add_remote"
        android:enabled="true"
        android:icon="@drawable/ic_shortcut_add_remote"
        android:shortcutShortLabel="@string/shortcut_add_remote_short"
        android:shortcutLongLabel="@string/shortcut_add_remote_long">
        <intent android:action="app.lusk.virga.action.SHORTCUT_ADD_REMOTE" />
    </shortcut>

</shortcuts>
