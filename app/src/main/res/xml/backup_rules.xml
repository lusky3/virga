<?xml version="1.0" encoding="utf-8"?>
<!-- Legacy backup rules for Android 11 and below (full-backup-content).
     Excludes the encrypted rclone config and the DataStore prefs directory
     (files/datastore/) which may contain sensitive OAuth state. -->
<full-backup-content>
    <exclude domain="file" path="rclone.conf.enc" />
    <exclude domain="file" path="datastore/" />
    <!-- Per-run sync logs record local folder paths + remote names; no reason to
         ship that operational metadata to cloud backup / device transfer. -->
    <exclude domain="file" path="run_logs/" />
</full-backup-content>
