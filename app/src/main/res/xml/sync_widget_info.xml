<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidget provider metadata for SyncWidget.
  minWidth/minHeight match a ~2×1 cell footprint (110dp × 50dp).
  updatePeriodMillis=0 means the system does not push periodic updates;
  the widget updates itself via GlanceAppWidget.update() after sync events.
  targetCellWidth/targetCellHeight are used on Android 12+ for the widget
  placement grid.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="110dp"
    android:minHeight="50dp"
    android:targetCellWidth="2"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/glance_default_loading_layout"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_description" />
