<?xml version="1.0" encoding="utf-8"?>
<!--
  F3 (0.3.0): paths the ${applicationId}.fileprovider may expose as content:// URIs.
  Scoped to a single `shared/` subdirectory of the app's internal and external cache,
  so consumers (config export, history export, file share/open/download) stage their
  transient artifacts under cacheDir/shared and nothing else is ever exposed.
-->
<paths>
    <cache-path name="shared" path="shared/" />
    <external-cache-path name="shared_external" path="shared/" />
</paths>
