<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules. rclone config (OAuth tokens) is excluded;
     task definitions and preferences are included. -->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="file" path="rclone.conf.enc" />
        <include domain="database" path="virga.db" />
        <include domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <exclude domain="file" path="rclone.conf.enc" />
        <include domain="database" path="virga.db" />
        <include domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
