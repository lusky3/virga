<?xml version="1.0" encoding="utf-8"?>
<!-- Android 12+ backup/transfer rules.
     Exclusions are intentionally broad: rclone.conf.enc (OAuth tokens) and the
     DataStore prefs directory (files/datastore/) must never leave the device.
     The <include domain="file" path="."> entry makes exclusions well-defined by
     explicitly opting in the whole files dir, then carving out secrets.
     Any new files added to filesDir are backed up by default; secrets are not. -->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="." />
        <exclude domain="file" path="rclone.conf.enc" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="run_logs/" />
        <!-- virga.db is deliberately NOT included, so (per the "only included domains
             are eligible" rule) it is never backed up or transferred. It holds sync-task
             topology — remote names, local + remote paths, filter patterns — the same
             operational metadata excluded as run_logs above. OAuth tokens live only in
             rclone.conf.enc (excluded); a restored db would point at remotes needing
             re-auth anyway, so tasks are simply re-created after a restore. -->
        <!-- No SharedPreferences are backed up/transferred: with explicit <include>
             rules present, only included domains are eligible, and sharedpref is
             deliberately never included — so a future dependency that quietly creates
             one can't leak its contents. (An explicit sharedpref <exclude> can't be
             used here: lint's FullBackupContent rejects an exclude with no matching
             include, and it would be redundant anyway.) -->

    </cloud-backup>
    <device-transfer>
        <include domain="file" path="." />
        <exclude domain="file" path="rclone.conf.enc" />
        <exclude domain="file" path="datastore/" />
        <exclude domain="file" path="run_logs/" />
        <!-- virga.db is deliberately NOT included, so (per the "only included domains
             are eligible" rule) it is never backed up or transferred. It holds sync-task
             topology — remote names, local + remote paths, filter patterns — the same
             operational metadata excluded as run_logs above. OAuth tokens live only in
             rclone.conf.enc (excluded); a restored db would point at remotes needing
             re-auth anyway, so tasks are simply re-created after a restore. -->
        <!-- No SharedPreferences are backed up/transferred: with explicit <include>
             rules present, only included domains are eligible, and sharedpref is
             deliberately never included — so a future dependency that quietly creates
             one can't leak its contents. (An explicit sharedpref <exclude> can't be
             used here: lint's FullBackupContent rejects an exclude with no matching
             include, and it would be redundant anyway.) -->

    </device-transfer>
</data-extraction-rules>
