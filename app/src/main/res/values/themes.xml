<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Launch theme: shows the system splash, then hands off to the Compose UI. -->
    <style name="Theme.Virga" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="postSplashScreenTheme">@style/Theme.Virga.Main</item>
    </style>

    <style name="Theme.Virga.Main" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowBackground">?attr/colorSurface</item>
    </style>
</resources>
